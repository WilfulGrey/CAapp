# CAapp (Vite/React Kundenportal) — local dev environment
#
# Skopiuj ten plik jako `.env.local` i uzupełnij wartościami otrzymanymi
# od Michała osobnym kanałem (Signal / encrypted email).
#
#   cp .env.example .env.local
#   # edytuj .env.local
#
# UWAGA: `.env.local` jest w .gitignore — NIE commituj.
# Real values tylko lokalnie.

# Beta Supabase project (development backend dla całego zespołu).
# Public URL — bezpieczny do commit'a, ale spójność trzymamy w env.
VITE_SUPABASE_URL=https://ycdwtrklpoqprabtwahi.supabase.co

# Public anon key — Supabase publishuje go dla browsera. ALE konsystentnie
# trzymamy go w env (nie hardcode'ujemy w kod).
VITE_SUPABASE_ANON_KEY=

# Diagnostic overlay w portalu (otwiera się gdy `?debug=1` w URL).
# 1 = enabled lokalnie, 0 = disabled (prod/beta default).
VITE_DEBUG=1
